{
  "name": "SimpleArduinoFake",
  "version": "2.0.0",
  "keywords": "test, mock, fake, arduino",
  "description": "Arduino mocking made easy.",
  "repository": {
    "type": "git",
    "url": "https://github.com/adbancroft/SimpleArduinoFake.git"
  },
  "authors": {
    "name": "Andrew Bancroft",
    "email": ""
  },
  "exclude": [
    "test"
  ],
  "build": {
    "libCompatMode": "off",
    "flags": [
        "-I src/arduino"
    ]
  },
  "frameworks": "arduino",
  "platforms": "native",
  "dependencies":
  {
    "fakeit": "https://github.com/eranpeer/FakeIt#2.4.0"
  }
}
